    //=========================================================================
 
    window.DC_Speak        = function (text, options) { DC_Voice.speak(text, options); };
    window.DC_Silence      = function ()              { DC_Voice.silence(); };
    window.DC_RepeatLast   = function ()              { DC_Voice.repeatLast(); };
